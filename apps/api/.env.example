# Backend API Environment Variables Template
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/seo_impact_os

# Token encryption — generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GSC and GA4 use separate redirect URIs
GOOGLE_GSC_REDIRECT_URI=http://localhost:3002/api/integrations/gsc/callback
GOOGLE_GA4_REDIRECT_URI=http://localhost:3002/api/integrations/ga4/callback

# Frontend URLs (for CORS + OAuth success redirect)
FRONTEND_URL=http://localhost:3002
FRONTEND_URL_PREVIEW=  # comma-separated Vercel preview URLs

# Cron authentication — generate: openssl rand -hex 32 (production only)
CRON_SECRET=

# Local dev only
API_PORT=3001
NODE_ENV=development
