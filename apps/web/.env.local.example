# Next.js + Hono (apps/web) Environment Variables
# Copy this to .env.local and fill in your values
# Hono API runs inside Next.js — all backend vars are needed here in production

# Frontend API URL — leave empty in production (same-origin Vercel deploy)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/seo_impact_os

# Token encryption — generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GSC_REDIRECT_URI=https://your-app.vercel.app/api/integrations/gsc/callback
GOOGLE_GA4_REDIRECT_URI=https://your-app.vercel.app/api/integrations/ga4/callback

# Frontend URLs (for CORS + OAuth success redirect)
FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL_PREVIEW=  # comma-separated Vercel preview URLs

# Cron authentication — generate: openssl rand -hex 32
CRON_SECRET=

NODE_ENV=production
