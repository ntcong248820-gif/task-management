{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "@seo-impact-os/web#build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "ENCRYPTION_KEY",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_GSC_REDIRECT_URI",
        "GOOGLE_GA4_REDIRECT_URI",
        "NEXT_PUBLIC_API_URL",
        "FRONTEND_URL",
        "FRONTEND_URL_PREVIEW",
        "CRON_SECRET"
      ],
      "outputs": [".next/**"]
    },
    "@seo-impact-os/api#build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "ENCRYPTION_KEY",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_GSC_REDIRECT_URI",
        "GOOGLE_GA4_REDIRECT_URI",
        "NEXT_PUBLIC_API_URL",
        "FRONTEND_URL",
        "CRON_SECRET"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "test": {
      "dependsOn": [],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
